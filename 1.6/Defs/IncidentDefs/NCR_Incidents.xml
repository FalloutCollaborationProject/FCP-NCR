<?xml version="1.0" encoding="UTF-8"?>
<Defs>

    <!--__________ Incidents __________-->

    <!-- California Grizzly Incident -->

    <IncidentDef>
        <defName>FCP_Incident_GrizzliesPass</defName>
        <label>Grizzlies Pass</label>
        <category>Misc</category>
        <targetTags>
            <li>Map_PlayerHome</li>
        </targetTags>
        <letterLabel>FCP_LetterLabel_GrizzliesPass</letterLabel>
        <letterText>FCP_Letter_GrizzliesPass</letterText>
        <workerClass>FCP.Core.IncidentWorker_AnimalPasses</workerClass>
        <baseChance>0.7</baseChance>
        <minRefireDays>13</minRefireDays>
        <modExtensions>
            <li Class="FCP.Core.ModExtension_AnimalPassesConfig">
                <animalThing>FCP_Animal_California_Grizzly</animalThing>
                <animalPawnKind>FCP_Animal_California_Grizzly</animalPawnKind>
                <minCount>1</minCount>
                <maxRangeInclusive>3~6</maxRangeInclusive>
                <ignoreTemperature>false</ignoreTemperature>
                <ignoreToxicFallout>true</ignoreToxicFallout>
            </li>
        </modExtensions>
    </IncidentDef>

    <IncidentDef>
        <defName>FCP_Incident_NCR_RangerOutpost</defName>
        <label>NCR Ranger Outpost appears</label>
        <category>Misc</category>
        <targetTags>
            <li>World</li>
        </targetTags>
        <workerClass>FCP.Factions.IncidentWorker_RandomFactionSite</workerClass>
        <baseChance>1.0</baseChance>
        <minRefireDays>20</minRefireDays>
        <letterLabel>NCR Ranger Outpost Discovered</letterLabel>
        <letterText>Your scouts have discovered an NCR Ranger outpost in the region.</letterText>
        <letterDef>NeutralEvent</letterDef>
        <modExtensions>
            <li Class="FCP.Factions.RandomSiteIncidentExtension">
                <targetFaction>FCP_Faction_NCR</targetFaction>
                <sitePartDef>FCP_SitePart_NCR_RangerOutpost</sitePartDef>
                <durationDays>15</durationDays>
                <maxActiveSites>2</maxActiveSites>
                <requiresPlayerVisible>true</requiresPlayerVisible>
                <searchRadius>40</searchRadius>
                <siteTemplate>
                    <guaranteedPawnKinds>
                        <FCP_Pawnkind_NCR_Ranger_Veteran>5</FCP_Pawnkind_NCR_Ranger_Veteran>
                    </guaranteedPawnKinds>
                    <allowedBiomes>
                        <li>Desert</li>
                        <li>AridShrubland</li>
                    </allowedBiomes>
                </siteTemplate>
            </li>
        </modExtensions>
    </IncidentDef>

</Defs>
