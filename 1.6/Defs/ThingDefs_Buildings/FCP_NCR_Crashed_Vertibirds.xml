<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!--__________ NCR Crashed Vertibirds __________-->

    <!-- NCR Crashed Vertibird -->

    <ThingDef ParentName="NonDeconstructibleAncientBuildingBase">
        <defName>FCP_NCR_Vertibird_Crashed</defName>
        <label>crashed NCR vertibird</label>
        <description>A destroyed NCR military vertibird transport. The bear flag of the New California Republic is still visible on the side. The crash site may contain useful NCR military equipment.</description>
        <rotatable>false</rotatable>
        <graphicData>
            <texPath>Things/Vehicles/FCP_NCR_Light_Vertibird_Crashed</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(9,9)</drawSize>
            <shadowData>
                <volume>(0.9, 0.7, 3.8)</volume>
            </shadowData>
        </graphicData>
        <size>(11,9)</size>
        <fillPercent>0.5</fillPercent>
        <passability>PassThroughOnly</passability>
        <pathCost>50</pathCost>
        <statBases>
            <MaxHitPoints>600</MaxHitPoints>
        </statBases>
        <killedLeavings>
            <ChunkSlagSteel>2</ChunkSlagSteel>
        </killedLeavings>
        <comps>
            <li Class="FCP.Core.CompProperties_UsableOnce">
                <useJob>UseItem</useJob>
                <useLabel>Search wreckage</useLabel>
                <showUseGizmo>true</showUseGizmo>
            </li>
            <li Class="FCP.Core.CompProperties_UseEffectItemBox">
                <numWeightedDrops>4</numWeightedDrops>
                <guaranteedDrops>
                </guaranteedDrops>
                <weightedDrops>
                    <!-- Currency -->
                    <li>
                        <thingDef>FCP_Currency_Caps</thingDef>
                        <countRange>1~80</countRange>
                    </li>
                    <li>
                        <thingDef>FCP_Currency_NCR_Dollar</thingDef>
                        <countRange>1~50</countRange>
                    </li>
                    <li>
                        <thingDef>FCP_Apparel_NCR_Engineer_Jumpsuit</thingDef>
                        <countRange>0~2</countRange>
                    </li>
                    <li>
                        <thingDef>FCP_Apparel_NCR_Trooper_Fatigues</thingDef>
                        <countRange>0~3</countRange>
                    </li>
                    <li>
                        <thingDef>FCP_Apparel_NCR_Trooper_Vest</thingDef>
                        <countRange>0~2</countRange>
                    </li>
                    <li>
                        <thingDef>FCP_Apparel_NCR_Trooper_Armor</thingDef>
                        <countRange>1</countRange>
                        <weight>0.8</weight>
                    </li>
                    <li>
                        <thingDef>FCP_Apparel_NCR_Beret</thingDef>
                        <countRange>1</countRange>
                    </li>
                    <li>
                        <thingDef>FCP_Apparel_NCR_Trooper_Helmet</thingDef>
                        <countRange>1~2</countRange>
                    </li>
                    <li>
                        <thingDef>FCP_Apparel_NCR_Goggles_Helmet</thingDef>
                        <countRange>0~1</countRange>
                        <weight>0.5</weight>
                    </li>
                    <li>
                        <thingDef>FCP_Gun_Service_Rifle</thingDef>
                        <countRange>0~2</countRange>
                    </li>
                    <li>
                        <thingDef>FCP_Gun_NCR_Hunting_Rifle</thingDef>
                        <countRange>0~1</countRange>
                        <weight>0.6</weight>
                    </li>
                    <li>
                        <thingDef>MedicineIndustrial</thingDef>
                        <countRange>0~5</countRange>
                    </li>
                    <li MayRequire="Rick.FCP.Wasteland.Food">
                        <thingDef>FCP_Food_NCR_Ration</thingDef>
                        <countRange>0~8</countRange>
                    </li>
                    <li>
                        <thingDef>MealSurvivalPack</thingDef>
                        <countRange>0~5</countRange>
                    </li>
                    <li MayRequire="Ludeon.RimWorld.Odyssey">
                        <thingDef>FCP_Vertibird_Engine</thingDef>
                        <countRange>0~1</countRange>
                        <weight>0.15</weight>
                    </li>
                    <li>
                        <thingDef>ComponentIndustrial</thingDef>
                        <countRange>0~4</countRange>
                        <weight>0.5</weight>
                    </li>
                </weightedDrops>
            </li>
            <li Class="FCP.Core.CompProperties_LabelColored">
                <rarity>Rare</rarity>
            </li>
        </comps>
    </ThingDef>

    <!-- NCR Crashed Vertibird Gunship -->

    <ThingDef ParentName="NonDeconstructibleAncientBuildingBase">
        <defName>FCP_NCR_Vertibird_Gunship_Crashed</defName>
        <label>crashed NCR vertibird gunship</label>
        <description>A destroyed NCR vertibird gunship. This heavily armed variant was used for combat operations. The wreckage may contain military-grade NCR equipment.</description>
        <rotatable>false</rotatable>
        <graphicData>
            <texPath>Things/Vehicles/FCP_NCR_Light_Vertibird_Crashed</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(9,9)</drawSize>
            <shadowData>
                <volume>(0.9, 0.7, 3.8)</volume>
            </shadowData>
        </graphicData>
        <size>(11,9)</size>
        <fillPercent>0.5</fillPercent>
        <passability>PassThroughOnly</passability>
        <pathCost>50</pathCost>
        <statBases>
            <MaxHitPoints>600</MaxHitPoints>
        </statBases>
        <killedLeavings>
            <ChunkSlagSteel>2</ChunkSlagSteel>
        </killedLeavings>
        <comps>
            <li Class="FCP.Core.CompProperties_UsableOnce">
                <useJob>UseItem</useJob>
                <useLabel>Search wreckage</useLabel>
                <showUseGizmo>true</showUseGizmo>
            </li>
            <li Class="FCP.Core.CompProperties_UseEffectItemBox">
                <numWeightedDrops>5</numWeightedDrops>
                <guaranteedDrops>
                </guaranteedDrops>
                <weightedDrops>
                    <!-- Currency -->
                    <li>
                        <thingDef>FCP_Currency_Caps</thingDef>
                        <countRange>50~100</countRange>
                    </li>
                    <li>
                        <thingDef>FCP_Currency_NCR_Dollar</thingDef>
                        <countRange>30~75</countRange>
                    </li>
                    <!-- NCR Apparel -->
                    <li>
                        <thingDef>FCP_Apparel_NCR_Trooper_Fatigues</thingDef>
                        <countRange>1~2</countRange>
                    </li>
                    <li>
                        <thingDef>FCP_Apparel_NCR_Trooper_Armor</thingDef>
                        <countRange>1~2</countRange>
                    </li>
                    <li>
                        <thingDef>FCP_Apparel_NCR_Trooper_Bandoleer_Armor</thingDef>
                        <countRange>1</countRange>
                        <weight>0.7</weight>
                    </li>
                    <li>
                        <thingDef>FCP_Apparel_NCR_Trooper_Mantle_Armor</thingDef>
                        <countRange>1</countRange>
                        <weight>0.5</weight>
                    </li>
                    <li>
                        <thingDef>FCP_Apparel_NCR_Scout_Recon_Armor</thingDef>
                        <countRange>1</countRange>
                        <weight>0.4</weight>
                    </li>
                    <!-- NCR Headgear -->
                    <li>
                        <thingDef>FCP_Apparel_NCR_Trooper_Helmet</thingDef>
                        <countRange>1~2</countRange>
                    </li>
                    <li>
                        <thingDef>FCP_Apparel_NCR_Goggles_Helmet</thingDef>
                        <countRange>1</countRange>
                        <weight>0.6</weight>
                    </li>
                    <li>
                        <thingDef>FCP_Apparel_NCR_Beret</thingDef>
                        <countRange>1</countRange>
                    </li>
                    
                    <!-- NCR Weapons (Military Grade) -->
                    <li>
                        <thingDef>FCP_Gun_Service_Rifle</thingDef>
                        <countRange>2~3</countRange>
                    </li>
                    <li>
                        <thingDef>FCP_Gun_NCR_Hunting_Rifle</thingDef>
                        <countRange>1</countRange>
                    </li>
                    <li>
                        <thingDef>FCP_Gun_Ranger_Sequoia</thingDef>
                        <countRange>1</countRange>
                        <weight>0.3</weight>
                    </li>
                    <!-- Medical Supplies -->
                    <li>
                        <thingDef>MedicineIndustrial</thingDef>
                        <countRange>3~6</countRange>
                    </li>
                    <li MayRequire="Rick.FCP.Chems">
                        <thingDef>FCP_Chem_Stimpak</thingDef>
                        <countRange>1~3</countRange>
                        <weight>0.5</weight>
                    </li>
                    <!-- Food and Supplies -->
                    <li MayRequire="Rick.FCP.Wasteland.Food">
                        <thingDef>FCP_Food_NCR_Ration</thingDef>
                        <countRange>5~10</countRange>
                    </li>
                    <li>
                        <thingDef>MealSurvivalPack</thingDef>
                        <countRange>3~7</countRange>
                    </li>
                    <!-- Vertibird Parts -->
                    <li MayRequire="Ludeon.RimWorld.Odyssey">
                        <thingDef>FCP_Vertibird_Engine</thingDef>
                        <countRange>1</countRange>
                        <weight>0.2</weight>
                    </li>
                    <li MayRequire="Ludeon.RimWorld.Odyssey">
                        <thingDef>Techprint_FCP_Vertibird_Construction</thingDef>
                        <countRange>1</countRange>
                        <weight>0.02</weight>
                    </li>
                    <li>
                        <thingDef>ComponentIndustrial</thingDef>
                        <countRange>3~6</countRange>
                    </li>
                    <li>
                        <thingDef>Plasteel</thingDef>
                        <countRange>5~15</countRange>
                        <weight>0.4</weight>
                    </li>
                </weightedDrops>
            </li>
            <li Class="FCP.Core.CompProperties_LabelColored">
                <rarity>Rare</rarity>
            </li>
        </comps>
    </ThingDef>

</Defs>
