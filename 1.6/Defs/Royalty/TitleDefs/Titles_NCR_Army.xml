<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!--__________ NCR Army Title Defs __________-->

    <!-- TitleBranchDef -->

    <FCP.Factions.TitleBranchDef>
        <label>NCR Armed Forces</label>
        <defName>FCP_TitleBranch_NCR_Army</defName>
    </FCP.Factions.TitleBranchDef>

    <!-- Abstract Base -->

    <RoyalTitleDef Name="FCP_Title_NCR_Army_Base" ParentName="FCP_Base_Empire_Titles" Abstract="True">
        <tags>
            <li>FCP_Title_NCR</li>
            <li>FCP_Title_NCR_Army</li>
        </tags>
        <awardWorkerClass>RoyalTitleAwardWorker_Instant</awardWorkerClass>
    </RoyalTitleDef>

    <!--___ NCR Army Titles ___-->

    <!-- NCR Private -->

    <RoyalTitleDef ParentName="FCP_Title_NCR_Army_Base">
        <defName>FCP_Title_NCR_PVT</defName>
        <label>NCR Army Private</label>
        <description>The lowest rank within the New California Republic's military. There isn't a lot of respect in this role, nor is the pay well.</description>
        <tags>
            <li>FCP_Title_NCR</li>
        </tags>
        <seniority>201</seniority>
        <favorCost>1</favorCost>
        <changeHeirQuestPoints>1000</changeHeirQuestPoints>
        <allowDignifiedMeditationFocus>False</allowDignifiedMeditationFocus>
        <permitPointsAwarded>1</permitPointsAwarded>
        <modExtensions>
            <li Class="FCP.Factions.TitleExtension_BranchTitle">
                <branchDef>FCP_TitleBranch_NCR_Army</branchDef>
                <seniority>1</seniority>
            </li>
        </modExtensions>
    </RoyalTitleDef>

    <!-- NCR Sergeant -->

    <RoyalTitleDef ParentName="FCP_Title_NCR_Army_Base">
        <defName>FCP_Title_NCR_SGT</defName>
        <label>NCR Army Sergeant</label>
        <description>The first rank within the New California Republic's non commissioned officer corps. This is the first step in a professional military carrer with reaL power and responsibilities.</description>
        <tags>
            <li>FCP_Title_NCR</li>
        </tags>
        <seniority>202</seniority>
        <favorCost>6</favorCost>
        <changeHeirQuestPoints>1000</changeHeirQuestPoints>
        <commonality>1</commonality>
        <allowDignifiedMeditationFocus>False</allowDignifiedMeditationFocus>
        <permitPointsAwarded>2</permitPointsAwarded>
        <modExtensions>
            <li Class="FCP.Factions.TitleExtension_BranchTitle">
                <branchDef>FCP_TitleBranch_NCR_Army</branchDef>
                <seniority>2</seniority>
            </li>
        </modExtensions>
    </RoyalTitleDef>

    <!-- NCR Lieutenant -->

    <RoyalTitleDef ParentName="FCP_Title_NCR_Army_Base">
        <defName>FCP_Title_NCR_LT</defName>
        <label>NCR Army Lieutenant</label>
        <description>The first rank within the New California Republic's commissioned officer corps. This is the lowest command position with the ability to call in reinforcements and supplies much faster and with greater quality and quantity.</description>
        <tags>
            <li>FCP_Title_NCR</li>
        </tags>
        <seniority>203</seniority>
        <favorCost>10</favorCost>
        <changeHeirQuestPoints>1000</changeHeirQuestPoints>
        <commonality>1</commonality>
        <allowDignifiedMeditationFocus>True</allowDignifiedMeditationFocus>
        <requiredApparel>
            <li>
                <bodyPartGroupsMatchAny>
                    <li>UpperHead</li>
                    <li>FullHead</li>
                </bodyPartGroupsMatchAny>
                <requiredTags>
                    <li>FCP_NCR_Trooper_Officer</li>
                </requiredTags>
            </li>
        </requiredApparel>
        <permitPointsAwarded>3</permitPointsAwarded>
        <modExtensions>
            <li Class="FCP.Factions.TitleExtension_BranchTitle">
                <branchDef>FCP_TitleBranch_NCR_Army</branchDef>
                <seniority>3</seniority>
            </li>
        </modExtensions>
    </RoyalTitleDef>

    <!-- NCR Captain -->

    <RoyalTitleDef ParentName="FCP_Title_NCR_Army_Base">
        <defName>FCP_Title_NCR_CPT</defName>
        <label>NCR Army Captain</label>
        <description>A mid-level commissioned officer in the New California Republic's military. Captains command companies and are responsible for the training and welfare of their soldiers in the field.</description>
        <tags>
            <li>FCP_Title_NCR</li>
        </tags>
        <seniority>204</seniority>
        <favorCost>10</favorCost>
        <changeHeirQuestPoints>1000</changeHeirQuestPoints>
        <commonality>1</commonality>
        <allowDignifiedMeditationFocus>True</allowDignifiedMeditationFocus>
        <requiredApparel>
            <li>
                <bodyPartGroupsMatchAny>
                    <li>UpperHead</li>
                    <li>FullHead</li>
                </bodyPartGroupsMatchAny>
                <requiredTags>
                    <li>FCP_NCR_Trooper_Officer</li>
                </requiredTags>
            </li>
        </requiredApparel>
        <permitPointsAwarded>3</permitPointsAwarded>
        <modExtensions>
            <li Class="FCP.Factions.TitleExtension_BranchTitle">
                <branchDef>FCP_TitleBranch_NCR_Army</branchDef>
                <seniority>4</seniority>
            </li>
        </modExtensions>
    </RoyalTitleDef>

    <!-- NCR Major -->

    <RoyalTitleDef ParentName="FCP_Title_NCR_Army_Base">
        <defName>FCP_Title_NCR_MAJ</defName>
        <label>NCR Army Major</label>
        <description>A senior commissioned officer in the New California Republic's military. Majors serve as executive officers or staff officers at the battalion level and above, coordinating operations across multiple units.</description>
        <tags>
            <li>FCP_Title_NCR</li>
        </tags>
        <seniority>205</seniority>
        <favorCost>12</favorCost>
        <changeHeirQuestPoints>1000</changeHeirQuestPoints>
        <commonality>1</commonality>
        <allowDignifiedMeditationFocus>True</allowDignifiedMeditationFocus>
        <requiredApparel>
            <li>
                <bodyPartGroupsMatchAny>
                    <li>UpperHead</li>
                    <li>FullHead</li>
                </bodyPartGroupsMatchAny>
                <requiredTags>
                    <li>FCP_NCR_Trooper_Officer</li>
                </requiredTags>
            </li>
        </requiredApparel>
        <permitPointsAwarded>4</permitPointsAwarded>
        <modExtensions>
            <li Class="FCP.Factions.TitleExtension_BranchTitle">
                <branchDef>FCP_TitleBranch_NCR_Army</branchDef>
                <seniority>5</seniority>
            </li>
        </modExtensions>
    </RoyalTitleDef>

    <!-- NCR Colonel -->

    <RoyalTitleDef ParentName="FCP_Title_NCR_Army_Base">
        <defName>FCP_Title_NCR_COL</defName>
        <label>NCR Army Colonel</label>
        <description>The highest rank achievable in the New California Republic without a political ally. This is one of the highest command positions with the ability to call in reinforcements at the company level and higher including special forces.</description>
        <tags>
            <li>FCP_Title_NCR</li>
        </tags>
        <seniority>206</seniority>
        <favorCost>14</favorCost>
        <changeHeirQuestPoints>1000</changeHeirQuestPoints>
        <commonality>1</commonality>
        <allowDignifiedMeditationFocus>True</allowDignifiedMeditationFocus>
        <requiredApparel>
            <li>
                <bodyPartGroupsMatchAny>
                    <li>UpperHead</li>
                    <li>FullHead</li>
                </bodyPartGroupsMatchAny>
                <requiredTags>
                    <li>FCP_NCR_Trooper_Officer</li>
                </requiredTags>
            </li>
        </requiredApparel>
        <permitPointsAwarded>5</permitPointsAwarded>
        <modExtensions>
            <li Class="FCP.Factions.TitleExtension_BranchTitle">
                <branchDef>FCP_TitleBranch_NCR_Army</branchDef>
                <seniority>6</seniority>
            </li>
        </modExtensions>
    </RoyalTitleDef>

    <!--___ Unobtainable ___-->

    <!-- NCR General -->

    <RoyalTitleDef ParentName="FCP_Title_NCR_Army_Base">
        <defName>FCP_Title_NCR_GEN</defName>
        <label>NCR General</label>
        <description>The highest military rank in the New California Republic. Generals command entire armies and answer only to the President and Congress. This rank is not awarded through normal service.</description>
        <tags>
            <li>FCP_Title_NCR</li>
        </tags>
        <seniority>207</seniority>
        <modExtensions>
            <li Class="FCP.Factions.TitleExtension_BranchTitle">
                <branchDef>FCP_TitleBranch_NCR_Army</branchDef>
                <seniority>7</seniority>
            </li>
        </modExtensions>
    </RoyalTitleDef>

</Defs>
