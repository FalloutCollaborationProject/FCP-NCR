<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!--__________ Powder Gangers Pawnkinds __________-->

    <!-- Powder Ganger -->

    <PawnKindDef ParentName="FCP_NCRkindBase">
        <defName>FCP_Pawnkind_Powder_Ganger</defName>
        <label>powder ganger</label>
        <race>Human</race>
        <combatPower>45</combatPower>
        <defaultFactionType>FCP_Faction_Powder_Gangers</defaultFactionType>
        <itemQuality>Poor</itemQuality>
        <gearHealthRange>0.4~0.8</gearHealthRange>
        <apparelMoney>200~400</apparelMoney>
        <weaponMoney>250~500</weaponMoney>
        <apparelRequired>
            <li>FCP_Apparel_NCRCF_Inmate_Uniform</li>
        </apparelRequired>
        <apparelTags>
            <li>FCP_NCRCF_Inmate</li>
        </apparelTags>
        <weaponTags>
            <li MayRequire="Rick.FCP.BallisticWeapons">FCP_Pistol</li>
            <li MayRequire="Rick.FCP.BallisticWeapons">FCP_Revolver</li>
            <li MayRequire="Rick.FCP.BallisticWeapons">FCP_Pipe_Pistol</li>
            <li MayRequire="Rick.FCP.BallisticWeapons">FCP_Pipe_Revolver</li>
        </weaponTags>
        <techHediffsMoney>50~50</techHediffsMoney>
        <techHediffsTags>
            <li>Poor</li>
        </techHediffsTags>
        <techHediffsChance>0.05</techHediffsChance>
        <requiredWorkTags>
            <li>Violent</li>
        </requiredWorkTags>
        <initialResistanceRange>8~20</initialResistanceRange>
        <initialWillRange>1~5</initialWillRange>
        <backstoryFiltersOverride>
            <li>
                <categoriesChildhood>
                    <li>FCP_Backstory_Wastelander_Child</li>
                </categoriesChildhood>
                <categoriesAdulthood>
                    <li>FCP_Backstory_Powder_Ganger</li>
                    <li>FCP_Backstory_NCRCF_Inmate</li>
                </categoriesAdulthood>
            </li>
        </backstoryFiltersOverride>
        <inventoryOptions>
            <skipChance>0.3</skipChance>
            <subOptionsChooseOne>
                <li>
                    <thingDef>FCP_Currency_Caps</thingDef>
                    <countRange>5~20</countRange>
                </li>
                <li>
                    <thingDef>Pemmican</thingDef>
                    <countRange>1~3</countRange>
                </li>
                <li MayRequire="Rick.FCP.MeleeWeapons">
                    <thingDef>FCP_Melee_Bat</thingDef>
                    <countRange>1</countRange>
                </li>
                <li MayRequire="Rick.FCP.MeleeWeapons">
                    <thingDef>FCP_Melee_Board_Spiked</thingDef>
                    <countRange>1</countRange>
                </li>
                <li MayRequire="Rick.FCP.MeleeWeapons">
                    <thingDef>FCP_Melee_Scrap_Pipe</thingDef>
                    <countRange>1</countRange>
                </li>
                <li MayRequire="Rick.FCP.Chems">
                    <thingDef>FCP_Chem_Diluted_Stimpak</thingDef>
                    <countRange>1~2</countRange>
                </li>
                <li MayRequire="Rick.FCP.Chems">
                    <thingDef>FCP_Chem_Jet</thingDef>
                    <countRange>1~2</countRange>
                </li>
                <li MayRequire="Rick.FCP.Chems">
                    <thingDef>FCP_Chem_Psycho</thingDef>
                    <countRange>1</countRange>
                </li>
                <li MayRequire="Rick.FCP.WastelandFood">
                    <thingDef>FCP_Food_Bug_Mush</thingDef>
                    <countRange>1~2</countRange>
                </li>
                <li MayRequire="Rick.FCP.WastelandFood">
                    <thingDef>FCP_Food_Black_Blood_Sausage</thingDef>
                    <countRange>1~2</countRange>
                </li>
                <li MayRequire="Rick.FCP.NukaCola">
                    <thingDef>FCP_Nuka_Cola</thingDef>
                    <countRange>1</countRange>
                </li>
            </subOptionsChooseOne>
        </inventoryOptions>
    </PawnKindDef>

