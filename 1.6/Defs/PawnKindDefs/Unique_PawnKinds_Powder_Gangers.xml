<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!--__________ Powder Gangers Unique Character PawnKinds __________-->

    <!--___ Base Definition ___-->

    <PawnKindDef Name="FCP_PowderGanger_UniqueCharacterBase" ParentName="FCP_NCRkindBase" Abstract="true">
        <showInDebugSpawner>false</showInDebugSpawner>
        <combatPower>65</combatPower>
        <defaultFactionType>FCP_Faction_Powder_Gangers</defaultFactionType>
        <itemQuality>Normal</itemQuality>
        <gearHealthRange>0.6~1.0</gearHealthRange>
        <apparelMoney>9999</apparelMoney>
        <apparelAllowHeadgearChance>0.5</apparelAllowHeadgearChance>
        <apparelIgnoreSeasons>true</apparelIgnoreSeasons>
        <weaponMoney>9999</weaponMoney>
        <initialWillRange>2~4</initialWillRange>
        <initialResistanceRange>10~20</initialResistanceRange>
        <requiredWorkTags>
            <li>Violent</li>
        </requiredWorkTags>
    </PawnKindDef>

    <!--___ Gang Leaders ___-->

    <!-- Samuel Cooke -->

    <PawnKindDef ParentName="FCP_PowderGanger_UniqueCharacterBase">
        <defName>FCP_Unique_Pawnkind_Samuel_Cooke</defName>
        <label>Samuel Cooke</label>
        <combatPower>95</combatPower>
        <apparelRequired>
            <li>FCP_Apparel_NCRCF_Inmate_Uniform</li>
        </apparelRequired>
        <apparelTags>
            <li>FCP_NCRCF_Inmate</li>
        </apparelTags>
        <weaponTags>
            <li MayRequire="Rick.FCP.BallisticWeapons">FCP_Assault_Rifle</li>
            <li MayRequire="Rick.FCP.BallisticWeapons">FCP_Marksman_Carbine</li>
        </weaponTags>
        <backstoryFiltersOverride>
            <li>
                <categoriesChildhood>
                    <li>FCP_Backstory_Wastelander_Child</li>
                </categoriesChildhood>
                <categoriesAdulthood>
                    <li>FCP_Backstory_Samuel_Cooke</li>
                </categoriesAdulthood>
            </li>
        </backstoryFiltersOverride>
        <inventoryOptions>
            <skipChance>0.1</skipChance>
            <subOptionsChooseOne>
                <li>
                    <thingDef>FCP_Currency_Caps</thingDef>
                    <countRange>50~120</countRange>
                </li>
                <li MayRequire="Rick.FCP.Chems">
                    <thingDef>FCP_Chem_Stimpak</thingDef>
                    <countRange>2~3</countRange>
                </li>
            </subOptionsChooseOne>
        </inventoryOptions>
    </PawnKindDef>

